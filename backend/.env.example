# Nexus AI Operations Platform - Environment Configuration Template

# Google APIs
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# AI Models configuration parameters
MODEL_NAME=gemini-3.5-flash
MODEL_NAME_TTS=gemini-3.1-flash-tts-preview
MODEL_NAME_LIVE=gemini-2.0-flash-exp
MODEL_NAME_TRANSLATE=gemini-1.5-flash
MODEL_NAME_IMAGE=imagen-3.0-generate-002
MODEL_NAME_OMNI=gemini-2.5-flash
INTERACTIONS_MODEL=gemini-2.5-pro
GEMMA_MODEL=gemma2-27b-it

# GCP Configurations
GCP_PROJECT_ID=your_gcp_project_id_here
BQ_DATASET=your_bigquery_dataset_here
GCS_BUCKET=your_gcs_bucket_here

# Cloud Run / SQL Postgres credentials
CLOUD_SQL_CONNECTION_NAME=project:region:instance
CLOUD_SQL_DATABASE=nexus_db
CLOUD_SQL_USER=postgres
CLOUD_SQL_PASSWORD=secret_password

# Hugging Face endpoint overrides (Optional)
HF_API_KEY=
HF_ENDPOINT=
LOCAL_MODEL=gemma-4-e4b

# Server & Demo settings
PORT=8000
DEBUG=true
DEMO_MODE=true
